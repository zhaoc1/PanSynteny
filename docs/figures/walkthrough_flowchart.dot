// PanSynteny path-generation flowchart (Steps 1-3)
// Render:  dot -Tpdf walkthrough_flowchart.dot -o walkthrough_flowchart.pdf
//          dot -Tpng -Gdpi=300 walkthrough_flowchart.dot -o walkthrough_flowchart.png
digraph pansynteny {
  rankdir = TB;
  splines = ortho;
  nodesep = 0.35;
  ranksep = 0.45;
  bgcolor = white;
  fontname = "Helvetica";

  // ---- defaults: process boxes ----
  node [shape=box, style="rounded,filled", fillcolor="#FFFFFF",
        color="#444444", penwidth=1.1, fontname="Helvetica", fontsize=10,
        margin="0.14,0.09"];
  edge [color="#444444", penwidth=1.1, arrowsize=0.8];

  // ---- data artefact style (helper macro via node attr overrides) ----
  // data nodes: shape=cylinder, light blue
  // (applied inline per node)

  // ===================== INPUTS =====================
  { rank = same;
    in1 [shape=cylinder, fillcolor="#EDE7F6", color="#5E35B1",
         label="Per-focal neighbor TSVs\n(±n flank per focal centroid)"];
    in2 [shape=cylinder, fillcolor="#EDE7F6", color="#5E35B1",
         label="Catalog c80 tables\n(centroid_80, gene_length)"];
  }

  // ===================== STEP 1 =====================
  subgraph cluster_s1 {
    label = "Step 1  -  Per-focal neighborhoods";
    fontname = "Helvetica-Bold"; fontsize = 11; labeljust = "l";
    style = "rounded,filled"; fillcolor = "#F3F6FB"; color = "#9DB2CE"; penwidth = 1.2;
    margin = 12;

    s1a [label="Extract focal-centered windows;\nlabel each neighbor by c80\n(coarse + fine; synthetic small-ORF labels)"];
    s1b [label="Set operon size = mode of the\nper-genome size distribution\n(density peak -> keep dominant bin)"];
    d1  [shape=cylinder, fillcolor="#E3F2FD", color="#1565C0",
         label="gene_neighbors\n(one row per focal x genome x position)"];
  }

  // ===================== STEP 2 =====================
  subgraph cluster_s2 {
    label = "Step 2  -  Per-genome assembly (OLC-style stitching)";
    fontname = "Helvetica-Bold"; fontsize = 11; labeljust = "l";
    style = "rounded,filled"; fillcolor = "#F2FAF4"; color = "#9CC7A8"; penwidth = 1.2;
    margin = 12;

    s2a [label="Per genome: pool ALL focal windows\ninto one directed graph\n(positional edges + edge support)"];
    s2b [label="DFS maximal paths\n= overlap assembly: windows fuse at\nshared genes -> one operon path"];
    d2  [shape=cylinder, fillcolor="#E3F2FD", color="#1565C0",
         label="path_df\n(one row per per-genome maximal path)"];
  }

  // ===================== STEP 3 =====================
  subgraph cluster_s3 {
    label = "Step 3  -  Cross-genome consolidation";
    fontname = "Helvetica-Bold"; fontsize = 11; labeljust = "l";
    style = "rounded,filled"; fillcolor = "#FDF6F0"; color = "#D8B79A"; penwidth = 1.2;
    margin = 12;

    s3a [label="Collapse identical path shapes"];
    s3b [label="Canonicalize direction (lex-min):\nmerge forward + reverse copies;\napply path_min_genomes cut"];
    dL1 [shape=cylinder, fillcolor="#FFF3E0", color="#E65100",
         label="L1  canonical operons"];
    s3c [label="Build joint components (gene-level\ngraph) and project onto paths"];
    s3d [label="Orient paths within each component\nto the longest reference path"];
    s3e [label="Expand by length-variant isoforms"];
    dL2 [shape=cylinder, fillcolor="#FFF3E0", color="#E65100",
         label="L2  per-isoform"];
    s3f [label="Per-genome expansion (needs_flip) +\ntruncation / fragmentation decorators"];
    dL3 [shape=cylinder, fillcolor="#FFF3E0", color="#E65100",
         label="L3  per-genome"];
  }

  // ===================== OUTPUT =====================
  out [shape=box, style="rounded,filled,dashed", fillcolor="#F5F5F5", color="#777777",
       fontcolor="#555555",
       label="Downstream: gggenes figures (Step 5),\ntrait-block extraction (Step 6)"];

  // ===================== EDGES (linear spine) =====================
  in1 -> s1a;
  in2 -> s1a;
  s1a -> s1b -> d1;
  d1  -> s2a;
  s2a -> s2b -> d2;
  d2  -> s3a;
  s3a -> s3b -> s3c -> s3d -> dL1;
  dL1 -> s3e -> dL2;
  dL2 -> s3f -> dL3;
  dL3 -> out;
}
